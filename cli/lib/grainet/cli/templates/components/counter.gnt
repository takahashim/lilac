<template>
  <div data-component="counter">
    <button data-ref="decrement" type="button">-</button>
    <span data-ref="count" class="count">0</span>
    <button data-ref="increment" type="button">+</button>
  </div>
</template>

<script type="text/ruby">
class Counter < Grainet::Component
  def setup
    @count = signal(0)
    refs.increment.on(:click) { @count.update(&:succ) }
    refs.decrement.on(:click) { @count.update(&:pred) }
    bind refs.count, text: @count
  end
end
</script>
