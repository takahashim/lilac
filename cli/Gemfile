# frozen_string_literal: true

source "https://rubygems.org"

gemspec

# Use the local wsv checkout during development so changes flow through
# without a rubygems publish cycle. When grainet-cli is released, the
# gemspec dependency resolves the published gem instead.
gem "wsv", path: "../wsv"

group :development do
  gem "minitest", "~> 5.0"
  gem "rake", "~> 13.0"
end
