# frozen_string_literal: true

source "https://rubygems.org"

gemspec

# Use a local wsv checkout when present so changes flow without a
# rubygems publish cycle. Falls through to the gemspec's ~> 0.10
# dependency (resolved from rubygems) when the sibling clone is absent
# — keeps CI builds working without cloning wsv too.
wsv_local = File.expand_path("../../wsv", __dir__)
gem "wsv", path: wsv_local if File.directory?(wsv_local)

# `lilac-wasm-bin` lives next to `cli/` as a sibling gem in this
# monorepo. Pulling it via `path:` means the `CompiledRuntimeResolver`
# soft-require can find `Lilac::Wasm::Bin` during dev / tests without
# a rubygems publish cycle. The scaffold Gemfile users get points at
# the published gem (no path:).
gem "lilac-wasm-bin", path: File.expand_path("../wasm-bin", __dir__)

group :development do
  gem "minitest", "~> 5.0"
  gem "rake", "~> 13.0"
  # Ruby-host DOM polyfill backing the wasmtime-rb test runner.
  # Maintained as a standalone gem in a sibling clone of this repo.
  gem "dommy", ">= 0.6"
end

# wasmtime-rb drives `mrbc-host.wasm` from the host Ruby in
# `WasmMrbcDriver`, replacing the external `mrbc` binary for the
# `lilac build --target compiled` flow. `mrbc-host.wasm` uses the wasm
# exception-handling proposal (mruby's setjmp/longjmp lowers through
# it), which needs `Engine.new(wasm_exceptions:)` — exposed since
# wasmtime-rb v45.0.0.
#
# A sibling `../../wasmtime-rb` checkout is used when present (lets us
# track upstream without a publish cycle); otherwise the published
# `~> 45.0` gem from the gemspec dependency resolves from rubygems.
wasmtime_local = File.expand_path("../../wasmtime-rb", __dir__)
if File.directory?(wasmtime_local)
  gem "wasmtime", path: wasmtime_local
else
  gem "wasmtime", "~> 45.0"
end
