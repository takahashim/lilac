# frozen_string_literal: true

source "https://rubygems.org"

gemspec

# Prefer a local wsv checkout when present; otherwise the gemspec's
# ~> 0.10 resolves from rubygems.
wsv_local = File.expand_path("../../wsv", __dir__)
gem "wsv", path: wsv_local if File.directory?(wsv_local)

# Sibling gem in this monorepo; `path:` lets CompiledRuntimeResolver's
# soft-require find Lilac::Wasm::Bin in dev without a publish cycle.
gem "lilac-wasm-bin", path: File.expand_path("../wasm-bin", __dir__)

group :development do
  gem "minitest", "~> 5.0"
  gem "rake", "~> 13.0"

  # Test-runner stack for the wasmtime-rb Ruby host: dommy (DOM polyfill)
  # + dommy-js-quickjs (real-JS engine; builds a native `quickjs` ext).
  # makiri (dommy's HTML backend) resolves transitively.
  gem "dommy", "~> 0.9"
  gem "dommy-js-quickjs", "~> 0.9"
end

# wasmtime-rb drives mrbc-host.wasm from Ruby (WasmMrbcDriver for
# `lilac build --target compiled`). Needs Engine.new(wasm_exceptions:)
# (wasmtime-rb >= 45) for mruby's setjmp/longjmp lowering. Sibling
# checkout when present, else ~> 45.0 from rubygems.
wasmtime_local = File.expand_path("../../wasmtime-rb", __dir__)
if File.directory?(wasmtime_local)
  gem "wasmtime", path: wasmtime_local
else
  gem "wasmtime", "~> 45.0"
end
