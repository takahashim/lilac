# frozen_string_literal: true

source "https://rubygems.org"

gemspec

# Use a local wsv checkout when present so changes flow without a
# rubygems publish cycle. Falls through to the gemspec's ~> 0.10
# dependency (resolved from rubygems) when the sibling clone is absent
# — keeps CI builds working without cloning wsv too.
wsv_local = File.expand_path("../../wsv", __dir__)
gem "wsv", path: wsv_local if File.directory?(wsv_local)

# `lilac-wasm-bin` lives next to `cli/` as a sibling gem in this
# monorepo. Pulling it via `path:` means the `CompiledRuntimeResolver`
# soft-require can find `Lilac::Wasm::Bin` during dev / tests without
# a rubygems publish cycle. The scaffold Gemfile users get points at
# the published gem (no path:).
gem "lilac-wasm-bin", path: File.expand_path("../wasm-bin", __dir__)

group :development do
  gem "minitest", "~> 5.0"
  gem "rake", "~> 13.0"
end
