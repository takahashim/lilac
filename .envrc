# direnv: auto-export MRUBY_WASM_RUNTIME_PATH for this repo.
#
# Run `direnv allow` after cloning. If you don't use direnv, set the
# variable manually in your shell:
#
#   export MRUBY_WASM_RUNTIME_PATH=$(cd .. && pwd)/mruby-wasm-runtime
#
# Adjust the path if your mruby-wasm-runtime clone lives elsewhere.

export MRUBY_WASM_RUNTIME_PATH="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")"/.. && pwd)/mruby-wasm-runtime"
