{
  "name": "@takahashim/lilac-compiled",
  "version": "0.1.0",
  "description": "Lilac frontend framework — compiled variant. Smallest bundle, requires pre-compiled bytecode via `lilac-cli` (Ruby gem). No runtime parser, no WASI io. Includes Regexp. Boot helper + wasm bundle.",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./wasm": "./lilac.wasm",
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "lilac.wasm",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "lilac",
    "ruby",
    "mruby",
    "webassembly",
    "wasm",
    "frontend",
    "framework",
    "signal",
    "reactive",
    "compiled",
    "bytecode"
  ],
  "author": "takahashim <takahashimm@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/takahashim/lilac#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/takahashim/lilac.git",
    "directory": "npm/lilac-compiled"
  },
  "bugs": {
    "url": "https://github.com/takahashim/lilac/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@takahashim/mruby-wasm-js": "^0.2.0"
  }
}
