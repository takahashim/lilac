{
  "name": "@takahashim/lilac-full",
  "version": "0.1.0",
  "description": "Lilac frontend framework — full variant (runtime parser + directive scanner + async + router + form + regexp-compat). Boot helper + wasm bundle.",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./wasm": "./lilac.wasm",
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "lilac.wasm",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "lilac",
    "ruby",
    "mruby",
    "webassembly",
    "wasm",
    "frontend",
    "framework",
    "signal",
    "reactive"
  ],
  "author": "takahashim <takahashimm@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/takahashim/lilac#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/takahashim/lilac.git",
    "directory": "npm/lilac-full"
  },
  "bugs": {
    "url": "https://github.com/takahashim/lilac/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@takahashim/mruby-wasm-js": "^0.2.0"
  }
}
