# Build outputs
/build/
/dist/

# Copy created by `make serve` so wsv can resolve example imports of
# `../mrbgem/...` from within the served root.
/mrbgem

# direnv local override
.envrc.local

# Editor / OS
.DS_Store
*.swp
*~

# Test artifacts
/node_modules/

# Local mrbgem.rake.lock generated during builds
build_config/*.lock

# Ruby gem build artifacts (cli/)
/cli/*.gem
/cli/.bundle/
/cli/Gemfile.lock
/cli/pkg/

# npm build artefacts: wasm copied by `make npm-pack` and `.mrb`
# plug-in bytecode produced by `make lilac-plugin-*`. JS / package.json
# / LICENSE / README stay tracked. node_modules itself ignores any wasm
# / mrb inside vendored deps, so these globs only affect tracked paths.
/npm/**/*.wasm
/npm/**/*.mrb

# npm
/npm/lilac-*/node_modules/
/npm/lilac-*/package-lock.json

# Misc
*.tsbuildinfo
