# Build outputs
/build/
/dist/

# Copy created by `make serve` so wsv can resolve example imports of
# `../mrbgem/...` from within the served root.
/mrbgem

# direnv local override
.envrc.local

# Editor / OS
.DS_Store
*.swp
*~

# Test artifacts
/node_modules/

# Local mrbgem.rake.lock generated during builds
build_config/*.lock

# Ruby gem build artifacts (cli/)
/cli/*.gem
/cli/.bundle/
/cli/Gemfile.lock
/cli/pkg/

# npm wasm artefacts copied by `make npm-pack` from build/*.release.wasm.
# JS / package.json / LICENSE / README stay tracked.
/npm/lilac-full/lilac.wasm
/npm/lilac-compiled/lilac.wasm

# npm
/npm/lilac-*/node_modules/
/npm/lilac-*/package-lock.json

# Misc
*.tsbuildinfo
