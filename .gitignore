# Build outputs
/build/
/dist/

# Copy created by `make serve` so wsv can resolve example imports of
# `../mrbgem/...` from within the served root.
/mrbgem

# direnv local override
.envrc.local

# Editor / OS
.DS_Store
*.swp
*~

# Test artifacts
/node_modules/

# Local mrbgem.rake.lock generated during builds
build_config/*.lock

# Ruby gem build artifacts (cli/)
/cli/*.gem
/cli/.bundle/
/cli/Gemfile.lock
/cli/pkg/

# npm build artefact: lilac-full.wasm copied by `make npm-pack` from
# the release build. JS / package.json / LICENSE / README stay tracked.
# `.mrb` glob remains for transitional cleanup — plug-in distribution
# moved to rubygems (decisions §25) so no production `.mrb` should land
# under npm/ anymore, but stale files from earlier builds may.
/npm/**/*.wasm
/npm/**/*.mrb

# npm
/npm/lilac-*/node_modules/
/npm/lilac-*/package-lock.json

# Misc
*.tsbuildinfo
